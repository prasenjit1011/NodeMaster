{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["jest"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}