// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Item {
  id    Int     @id @default(autoincrement())
  name  String? @db.VarChar(100)
  price Float?

  @@map("items")
}

model Customer {
  id       Int     @id @default(autoincrement())
  name     String?
  email    String  @unique
  password String

  @@map("customers")
}