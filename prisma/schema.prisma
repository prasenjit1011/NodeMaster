generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Item {
  id          Int           @id @default(autoincrement())
  name        String?       @db.VarChar(100)
  price       Float?        @db.Float
  order_items order_items[]

  @@map("items")
}

model Customer {
  id       Int      @id @default(autoincrement())
  name     String?  @db.VarChar(100)
  email    String?  @unique(map: "ix_customers_email") @db.VarChar(100)
  password String?  @db.VarChar(255)
  orders   orders[]

  @@index([id], map: "ix_customers_id")
  @@map("customers")
}

model alembic_version {
  version_num String @id @db.VarChar(32)
}

model order_items {
  id       Int     @id @default(autoincrement())
  order_id Int?
  item_id  Int?
  quantity Int?
  orders   orders? @relation(fields: [order_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_1")
  items    Item?   @relation(fields: [item_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_2")

  @@index([item_id], map: "item_id")
  @@index([order_id], map: "order_id")
}

model orders {
  id          Int           @id @default(autoincrement())
  customer_id Int?
  order_items order_items[]
  customers   Customer?     @relation(fields: [customer_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "orders_ibfk_1")

  @@index([customer_id], map: "customer_id")
}

model Country {
  id          Int      @id @default(autoincrement())
  countryname String   @unique @db.VarChar(100)
  status      Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @updatedAt @db.Timestamp(0)

  @@map("countries")
}

