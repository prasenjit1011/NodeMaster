{
  "name": "employee-system",
  "version": "1.0.0",
  "description": "NodeJS AWS Lambda Employee Management System with Terraform, Step Functions, MongoDB and GitHub Actions",
  "main": "index.js",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rmdir /s /q zips 2>nul & mkdir zips",

    "install:login": "cd lambdas/login && npm install",
    "zip:login": "cd lambdas/login && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/login.zip -Force",

    "install:validateJwt": "cd lambdas/validateJwt && npm install",
    "zip:validateJwt": "cd lambdas/validateJwt && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/validateJwt.zip -Force",

    "install:createEmployee": "cd lambdas/createEmployee && npm install",
    "zip:createEmployee": "cd lambdas/createEmployee && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/createEmployee.zip -Force",

    "install:updateEmployee": "cd lambdas/updateEmployee && npm install",
    "zip:updateEmployee": "cd lambdas/updateEmployee && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/updateEmployee.zip -Force",

    "install:uploadImage": "cd lambdas/uploadImage && npm install",
    "zip:uploadImage": "cd lambdas/uploadImage && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/uploadImage.zip -Force",

    "install:seedAdmin": "cd lambdas/seedAdmin && npm install",
    "zip:seedAdmin": "cd lambdas/seedAdmin && powershell Compress-Archive -Path index.js,package.json,node_modules -DestinationPath ../../zips/seedAdmin.zip -Force",

    "build": "npm run clean && npm run install:login && npm run zip:login && npm run install:validateJwt && npm run zip:validateJwt && npm run install:createEmployee && npm run zip:createEmployee && npm run install:updateEmployee && npm run zip:updateEmployee && npm run install:uploadImage && npm run zip:uploadImage && npm run install:seedAdmin && npm run zip:seedAdmin",

    "terraform:init": "cd terraform && terraform init",

    "terraform:validate": "cd terraform && terraform validate",

    "terraform:plan": "cd terraform && terraform plan",

    "terraform:apply": "cd terraform && terraform apply -auto-approve",

    "terraform:destroy": "cd terraform && terraform destroy -auto-approve",

    "deploy": "npm run build && npm run terraform:init && npm run terraform:validate && npm run terraform:apply"
  },
  "keywords": [
    "aws",
    "lambda",
    "terraform",
    "mongodb",
    "step-functions",
    "github-actions",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {}
}
