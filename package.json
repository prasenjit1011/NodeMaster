{
  "name": "nodejsmongodbtodo",
  "version": "1.0.0",
  "description": "Node.js + TypeScript + MongoDB + Terraform + GCP",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --project tsconfig.json src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "mongodb",
    "terraform",
    "gcp",
    "express",
    "jest"
  ],
  "author": "Prasenjit",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.1",
    "body-parser": "^1.20.2",
    "dotenv": "^17.4.2",
    "ejs": "^3.1.10",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "fs-extra": "^11.3.5",
    "mongodb": "^6.3.0",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
