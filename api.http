### =========================================
### LEAVE APPROVAL SYSTEM API
### =========================================

@baseUrl = https://vefrzob4u2.execute-api.ap-south-1.amazonaws.com/


### =========================================
### 1. APPLY FOR LEAVE (Employee)
### =========================================
POST {{baseUrl}}/leave/apply
Content-Type: application/json

{
  "employeeId": "EMP001",
  "employeeName": "Testing Demo Employee",
  "email": "prasenjit10112@gmail.com",
  "fromDate": "2026-06-10",
  "toDate": "2026-06-12",
  "reason": "Personal work",
  "leaveType": "casual"
}


### =========================================
### 2. APPROVE LEAVE (Manager)
### =========================================
POST {{baseUrl}}/leave/approve
Content-Type: application/json

{
  "requestId": "LEAVE-12345",
  "approvedBy": "MANAGER001",
  "status": "approved",
  "comment": "Approved for valid reason"
}


### =========================================
### 3. REJECT LEAVE (Manager / HR)
### =========================================
POST {{baseUrl}}/leave/reject
Content-Type: application/json

{
  "requestId": "LEAVE-12345",
  "rejectedBy": "MANAGER001",
  "status": "rejected",
  "comment": "Insufficient leave balance"
}


### =========================================
### 4. GET LEAVE STATUS (Optional)
### =========================================
GET {{baseUrl}}/leave/status/LEAVE-12345
Accept: application/json


### =========================================
### 5. HEALTH CHECK (if implemented)
### =========================================
GET {{baseUrl}}/health