{
    "compilerOptions": {
        "target": "es6",
        "module": "commonjs",
        "moduleResolution": "node10",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "skipLibCheck": true,
        "resolvePackageJsonExports": false,
        "resolvePackageJsonImports": false,
