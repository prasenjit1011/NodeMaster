##################################################
### 🔹 Home
GET {{baseUrl}}/

##################################################
### 🔹 Register User
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "John",
  "email": "Fjohn@example.com",
  "password": "123456"
}

##################################################
### 🔹 Login User (Store Token)
POST {{baseUrl}}/auth/login
Content-Type: application/json; charset=utf-8

{
  "email": "ajohn@example.com",
  "password": "123456"
}
# > {{#setToken response.body.token}}
##################################################
### 🔹 Get All Items
GET {{baseUrl}}/items

##################################################
### 🔐 Create Item (Without Auth - Not Protected)
POST {{baseUrl}}/items
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "New Item 12DG",
  "price": 145
}

##################################################
### 🔐 Update Item (Protected)
PUT {{baseUrl}}/items/25
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Updated Item DPP",
  "price": 200
}

##################################################
### 🔹 Get Item Details
GET {{baseUrl}}/items/1


##################################################
### 🔐 Create Orders (Protected)
POST {{baseUrl}}/customers/orders
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "items": [
    { "item_id": 2, "quantity": 3 },
    { "item_id": 1, "quantity": 51 }
  ]
}

##################################################
### 🔹 Get All Countries
GET {{baseUrl}}/countries

##################################################
### 🔹 Create Country
POST {{baseUrl}}/countries
Content-Type: application/json

{
  "countryname": "UAE",
  "status": true
}

##################################################
### 🔹 Update Country
PUT {{baseUrl}}/countries/2
Content-Type: application/json

{
  "countryname": "Norway",
  "status": true
}

##################################################
### 🔹 Get Country Details
GET {{baseUrl}}/countries/1

##################################################
### 🔹 Delete Country
DELETE {{baseUrl}}/countries/1

##################################################
### 🔹 Test Uniqueness Validation - Create Duplicate (Should Fail)
POST {{baseUrl}}/countries
Content-Type: application/json

{
  "countryname": "United States",
  "status": true
}

# Expected: 409 Conflict - "Country name already exists"

##################################################
### 🔹 Test Uniqueness Validation - Update to Duplicate (Should Fail)
PUT {{baseUrl}}/countries/2
Content-Type: application/json

{
  "countryname": "India"
}

# Expected: 409 Conflict - "Country name already exists"
